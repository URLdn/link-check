{
  "name": "urldn-link-check",
  "version": "1.0.1",
  "description": "Scan Markdown and documentation for broken links, redirect chains, insecure HTTP links, and excessively long URLs. Usable as a CLI or a GitHub Action.",
  "keywords": [
    "link-checker",
    "markdown",
    "broken-links",
    "github-action",
    "cli",
    "documentation",
    "url",
    "redirect",
    "https",
    "urldn"
  ],
  "homepage": "https://github.com/urldn/link-check#readme",
  "bugs": {
    "url": "https://github.com/urldn/link-check/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/urldn/link-check.git"
  },
  "license": "MIT",
  "author": "URLDN <hello@urldn.com> (https://www.urldn.com)",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "urldn-link-check": "./dist/cli.js"
  },
  "files": [
    "dist",
    "action.yml",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build",
    "start": "node dist/cli.js"
  },
  "dependencies": {
    "@actions/core": "^1.10.1",
    "@actions/github": "^6.0.0",
    "@actions/io": "^1.1.3",
    "axios": "^1.7.7",
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "glob": "^11.0.0",
    "ora": "^8.1.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@eslint/js": "^9.11.1",
    "@types/node": "^22.7.4",
    "eslint": "^9.11.1",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.3.3",
    "tsup": "^8.3.0",
    "typescript": "^5.6.2",
    "typescript-eslint": "^8.8.0",
    "vitest": "^2.1.1"
  }
}
